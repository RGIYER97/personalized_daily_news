# ==============================================
# Daily News Briefing — Environment Variables
# Copy this file to .env and fill in your values
# ==============================================
# RSS feeds (WSJ, CNBC, NPR, BBC, NYT, Google News) need NO keys — they are public.
# Only NEWSAPI_KEY and GEMINI_API_KEY go here (plus email/SMS below).

# --- News API (https://newsapi.org — free tier: 100 req/day) ---
NEWSAPI_KEY=

# --- Google Gemini API (https://aistudio.google.com/apikey — free tier available) ---
# Required for blunt summaries (news + stocks). Without it, output is mostly raw headlines.
GEMINI_API_KEY=

# --- SMS via Email-to-SMS Gateway (100% free, no sign-up needed) ---
# Your 10-digit US phone number
USER_PHONE=2125551234
# Your carrier (see README for supported carriers)
USER_CARRIER=tmobile

# --- Email settings (required for both SMS gateway and email fallback) ---
# For Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
USER_EMAIL=you@example.com
SMTP_EMAIL=you@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Schedule (24hr format, EST timezone — only used for local `python main.py`) ---
SEND_TIME=07:00
